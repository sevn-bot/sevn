# Operator Docker stack (copy to `.env` in repo root; `.env` is gitignored).
#
#   cp .env.example .env
#   make compose-up
#   docker compose run --rm sevn-gateway sevn onboard --config /bootstrap/onboard-compose.json --profile good_value_docker --no-install-daemon --no-start-services --no-prompt-bot-name --bot-name Sevn
#   curl -sf http://127.0.0.1:${SEVN_GATEWAY_PORT:-3001}/ready

SEVN_TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# Host port published for sevn-gateway (container listens on 3001).
SEVN_GATEWAY_PORT=3001

# Browser skills (playwright-browser, x-use, facebook-use) require the browser extra:
#   uv sync --extra browser && playwright install chromium

# Playwright `--target prod` (host runner; optional).
TG_TARGET_BOT=
TEST_DEPLOYMENT_ID=

# Playwright headed by default; set TELEGRAM_TEST_HEADLESS=1 or pass --headless to hide the browser.
# TELEGRAM_TEST_VIEWPORT_WIDTH=1920
# TELEGRAM_TEST_VIEWPORT_HEIGHT=1080
# Headed runs fit to screen.avail*; lower height if the composer is still clipped.
# TELEGRAM_TEST_DEVICE_SCALE_FACTOR=1
# TELEGRAM_TEST_BROWSER_CHANNEL=chrome
# Optional: use system Chrome instead of Playwright-bundled Chromium (playwright install chrome)
# TELEGRAM_TEST_ECHO_MODE=1
# Only for prod when the remote gateway has SEVN_E2E_ECHO_TURN=1; local target enables echo via compose override.

# --- Where is the sevn.bot *source code* on disk? ---
# Running gateway/Telegram bot: set my_sevn.repo_path in ~/.sevn/workspace/sevn.json
# (absolute path to the git clone). That drives @repo/ reads and code orientation.
# Do not rely on the vars below for a normal install.
#
# SEVN_REPO_ROOT — optional dev/CLI hint: "this shell session's sevn.bot checkout".
# Used when you run commands from a terminal (sevn sync, sevn doctor, pytest) and
# my_sevn.repo_path is not set yet. Example: the repo you are editing in Cursor.
# SEVN_REPO_ROOT=/Users/you/code/sevn
#
# SEVN_SOURCE_ROOT — optional install hint: "where sevn was installed from" (git clone).
# Used by sevn unboard --with-source to delete that checkout, and as a fallback if
# SEVN_REPO_ROOT is unset. Often the same path as SEVN_REPO_ROOT on a dev machine.
# SEVN_SOURCE_ROOT=/Users/you/code/sevn

# Telegram E2E tester (tools/telegram-tester; host-only; see docs/runbooks/telegram-e2e.md).
# Session profile: tools/telegram-tester/.browser-profile/
# JSON/screenshots: tools/telegram-tester/artifacts/

# Onboarding wizard GitHub OAuth App (host-only `sevn onboard --web`; not gateway).
# Register callback: http://127.0.0.1:{onboard_port}/api/github/oauth/callback
# Default onboard_port is 8844 (`sevn onboard --web --port 8844`).
# Scopes: repo, read:user (minimum). Never commit real client secret values.
# SEVN_GITHUB_OAUTH_CLIENT_ID=
# SEVN_GITHUB_OAUTH_CLIENT_SECRET=

# Gateway bearer for /login and authenticated HTTP routes (optional on pure-loopback dev).
# Prefer `sevn gateway set-gateway-token` to store in the secrets chain; env is a dev fallback.
SEVN_GATEWAY_TOKEN=change-me
# Egress LLM proxy base URL the gateway calls (see `make proxy`).
SEVN_PROXY_URL=http://127.0.0.1:8787
# Secrets-store passphrase fallback (macOS daemons read it from Keychain instead).
SEVN_SECRETS_PASSPHRASE=change-me

# CodeRabbit CLI advisory reviews (`make review` after `make coderabbit-install`; W5).
# Agentic API key from https://app.coderabbit.ai/settings/api-keys — never commit real values.
# CODERABBIT_API_KEY=
