{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sevn.bot/schemas/coding-agents-hub.schema.json",
  "title": "Coding Agents Hub architecture report",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "sevn_baseline",
    "agent_types_v1",
    "binding_model",
    "executor_backends_v1",
    "sevn_invoke",
    "hard_dependencies",
    "mc_tab"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "required": ["article", "lap_repo"],
      "properties": {
        "article": { "type": "string", "minLength": 1 },
        "lap_repo": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "sevn_baseline": {
      "type": "object",
      "required": [
        "mc_tab",
        "telegram_binding",
        "cursor_delegation",
        "long_running_loop",
        "external_agent_plane"
      ],
      "properties": {
        "mc_tab": { "type": "string" },
        "telegram_binding": { "type": "string" },
        "cursor_delegation": { "type": "string" },
        "long_running_loop": { "type": "string" },
        "external_agent_plane": { "type": "string" }
      },
      "additionalProperties": false
    },
    "agent_types_v1": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["type", "description", "modules"],
        "properties": {
          "type": { "type": "string", "enum": ["alrca", "litellm_lap"] },
          "description": { "type": "string", "minLength": 1 },
          "modules": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "deployment": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "binding_model": {
      "type": "object",
      "required": ["config_path", "shape", "routing", "migration"],
      "properties": {
        "config_path": { "type": "string" },
        "shape": {
          "type": "object",
          "required": ["chat_id", "topic_ids"],
          "properties": {
            "chat_id": { "type": "string" },
            "topic_ids": { "type": "string" }
          },
          "additionalProperties": false
        },
        "routing": { "type": "string" },
        "migration": { "type": "string" }
      },
      "additionalProperties": false
    },
    "executor_backends_v1": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "transport", "reuse"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["claude_code", "cursor", "codex"]
          },
          "transport": { "type": "string" },
          "reuse": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "sevn_invoke": {
      "type": "object",
      "required": ["tool", "tier"],
      "properties": {
        "tool": { "type": "string" },
        "tier": { "type": "string" }
      },
      "additionalProperties": false
    },
    "hard_dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mc_tab": {
      "type": "object",
      "required": ["slug_replace", "wired_slugs"],
      "properties": {
        "slug_replace": { "type": "string" },
        "wired_slugs": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
