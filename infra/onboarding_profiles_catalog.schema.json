{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sevn.bot/infra/onboarding_profiles_catalog.schema.json",
  "title": "Onboarding profile catalog",
  "description": "Shape of `src/sevn/data/onboarding_profiles/onboarding_profiles.json` (`specs/22-onboarding.md` §3.1).",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "profile_id",
      "title",
      "short_description",
      "capabilities_summary",
      "tags",
      "model",
      "host"
    ],
    "properties": {
      "profile_id": { "type": "string", "minLength": 1 },
      "title": { "type": "string" },
      "short_description": { "type": "string" },
      "capabilities_summary": {
        "type": "string",
        "minLength": 1,
        "description": "One-line capability preset summary for profile card subtitle (`onboarding-comprehensive-setup` D13 W10)."
      },
      "tags": {
        "type": "array",
        "items": { "type": "string" }
      },
      "model": { "type": "string", "minLength": 1 },
      "host": {
        "type": "string",
        "enum": ["docker", "osx", "cloud"]
      }
    },
    "additionalProperties": true
  }
}
