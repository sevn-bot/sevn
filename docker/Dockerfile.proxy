# SPDX-License-Identifier: MIT
# Egress LLM proxy — uvicorn ASGI (specs/07-egress-proxy.md §2.1).

FROM python:3.12-slim-bookworm

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /opt/sevn
COPY pyproject.toml uv.lock README.md ./
COPY src/sevn ./src/sevn
# Required by the hatchling wheel force-include in pyproject.toml.
COPY infra/sevn.schema.json ./infra/sevn.schema.json

RUN uv sync --frozen --no-dev

ENV PATH="/opt/sevn/.venv/bin:${PATH}"

EXPOSE 8787

CMD ["uvicorn", "sevn.proxy.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "8787"]
