<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }} — sevn.bot help</title>
  <link rel="icon" href="assets/logos/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="assets/index.css" />
  <style>
    .help-shell { display: grid; grid-template-columns: 220px 1fr; gap: 2rem; max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
    @media (max-width: 800px) { .help-shell { grid-template-columns: 1fr; } }
    .help-nav { position: sticky; top: 1rem; align-self: start; }
    .help-nav a { display: block; padding: 0.35rem 0; color: var(--sevn-fg-muted); text-decoration: none; font-size: 0.92rem; }
    .help-nav a:hover, .help-nav a.active { color: var(--sevn-primary); }
    .help-main h1 { margin-top: 0; font-size: 1.75rem; color: var(--sevn-fg-strong); }
    .help-summary { color: var(--sevn-fg-muted); font-size: 1.05rem; margin-bottom: 1.5rem; max-width: 60ch; }
    .help-footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--sevn-border); font-size: 0.78rem; color: var(--sevn-fg-muted); }
    .help-generated-note { font-size: 0.85rem; color: var(--sevn-fg-muted); font-style: italic; margin-bottom: 1rem; }
    .help-body p { line-height: 1.6; max-width: 65ch; }
    .help-body ul, .help-body ol { max-width: 65ch; line-height: 1.6; }
    .help-body a { color: var(--sevn-primary); }
    .catalog-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; margin: 1rem 0; }
    .catalog-table th, .catalog-table td { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--sevn-border); vertical-align: top; }
    .catalog-table th { color: var(--sevn-fg-muted); font-weight: 600; }
    .badge { display: inline-block; font-size: 0.72rem; padding: 0.15rem 0.5rem; border-radius: 4px; }
    .badge-available { background: #1b3d1f; color: #81c784; }
    .badge-soon { background: #4a3410; color: #ffb74d; }
    .badge-unavailable { background: #333; color: #bbb; }
  </style>
  {% block extra_head %}{% endblock %}
</head>
<body>
  <div class="help-shell">
    <nav class="help-nav" aria-label="Help pages">
      <strong style="display:block;margin-bottom:0.75rem;color:var(--sevn-fg-strong);">sevn.bot help</strong>
      {% for href, label in nav_pages %}
      <a href="{{ href }}"{% if slug ~ '.html' == href %} class="active"{% endif %}>{{ label }}</a>
      {% endfor %}
    </nav>
    <main class="help-main">
      <h1>{{ title }}</h1>
      {% if summary %}<p class="help-summary">{{ summary }}</p>{% endif %}
      {% if is_generated_catalog %}
      <p class="help-generated-note">This page is updated automatically when the product changes.</p>
      {% endif %}
      {% block content %}{% endblock %}
      <footer class="help-footer">
        Generated {{ generated_at }} from commit {{ git_commit }}.
        Edit <code>about-sevn.bot/_sources/{{ slug }}.yaml</code> or templates — not the HTML directly.
      </footer>
    </main>
  </div>
  {% block extra_scripts %}{% endblock %}
</body>
</html>
